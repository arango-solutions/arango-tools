# Configuration for the Arango Tools GUI backend.
#
# All values are optional and use the ARANGO_ prefix. For local development you
# can copy this file to .env; in a container/Kubernetes deployment, supply these
# as environment variables instead (env vars always take precedence over .env).

# --- ArangoDB connection defaults ---------------------------------------------
# Endpoint of the ArangoDB instance. Accepts http(s):// or the tools'
# tcp:///ssl:// form. http(s) URLs are converted automatically. If omitted, you
# can enter connection details manually in the GUI.
ARANGO_ENDPOINT=http://localhost:8529

# Target database (defaults to _system if blank).
ARANGO_DATABASE=_system

# Credentials.
ARANGO_USERNAME=root
ARANGO_PASSWORD=

# --- Runtime / tooling --------------------------------------------------------
# Directory containing the arango* client binaries. If unset, the tools are
# expected to be on the PATH. The container image sets this for you.
ARANGO_TOOLS_BIN=

# Directory of the built frontend (the Vite "dist" output). When set, the
# backend serves the UI itself so the API and UI share a single origin. Leave
# unset for local dev, where the Vite dev server serves the UI. The container
# image sets this for you.
ARANGO_STATIC_DIR=

# Comma-separated list of allowed CORS origins. Only relevant when the UI is
# served from a different origin than the API (e.g. the Vite dev server). When
# the backend serves the static bundle (single origin) this is unused.
ARANGO_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional explicit path to a .env file to load (env vars still win over it).
# ARANGO_ENV_FILE=/etc/arango-tools/.env
