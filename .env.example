# ArangoDB connection defaults for the Arango Tools GUI backend.
# Copy to .env and fill in. All values are optional; if omitted, you can
# enter connection details manually in the GUI instead.

# Endpoint of the ArangoDB instance. Accepts http(s):// or the tools'
# tcp:///ssl:// form. http(s) URLs are converted automatically.
ARANGO_ENDPOINT=http://localhost:8529

# Target database (defaults to _system if blank).
ARANGO_DATABASE=_system

# Credentials.
ARANGO_USERNAME=root
ARANGO_PASSWORD=

# Optional: directory containing the arango* client binaries. If unset,
# the tools are expected to be on the PATH.
ARANGO_TOOLS_BIN=
